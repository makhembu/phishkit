{
  "name": "phishkit",
  "version": "1.0.0",
  "description": "Phishing analysis pipeline. URL pattern analysis, DOM structure inspection, and LLM-assisted phishing assessment.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "analyze": "tsx src/analysis/url.ts",
    "lint": "tsc --noEmit",
    "test": "npx tsx --test tests/*.test.ts"
  },
  "keywords": ["phishing", "security-analysis", "url-scanning", "threat-intel", "soc"],
  "license": "MIT",
  "dependencies": {
    "hono": "^4.7.0",
    "better-sqlite3": "^11.8.0",
    "dotenv": "^16.4.0",
    "node-fetch": "^3.3.0",
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "tsx": "^4.19.0"
  }
}
